<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ErgStream.Pages.ErgDataStreamPage"
             Title="Erg Data Stream">
    
    <Grid RowDefinitions="*,Auto" Padding="10">
        
        <!-- Data Display Area -->
        <ScrollView x:Name="DataScrollView" Grid.Row="0">
            <Label x:Name="DataLabel" 
                   Text="{Binding DataText}"
                   FontFamily="Courier"
                   FontSize="12"
                   VerticalOptions="Start"/>
        </ScrollView>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="0"
                          IsRunning="{Binding IsConnecting}"
                          IsVisible="{Binding IsConnecting}"
                          Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Primary}}"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"/>

        <!-- Button Panel -->
        <HorizontalStackLayout Grid.Row="1" 
                              Spacing="10"
                              HorizontalOptions="Center"
                              Margin="0,10,0,0">
            
            <Button Text="Clear"
                    Command="{Binding ClearCommand}"
                    WidthRequest="120"/>
            
            <Button Text="Copy"
                    Command="{Binding CopyCommand}"
                    WidthRequest="120"/>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>