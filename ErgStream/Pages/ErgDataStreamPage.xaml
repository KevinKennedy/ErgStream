<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ErgStream.Pages.ErgDataStreamPage"
             Title="Erg Data Stream">

    <Grid RowDefinitions="Auto,*" Padding="10">

        <!-- Action Buttons -->
        <HorizontalStackLayout Grid.Row="0" 
                              Spacing="10" 
                              Margin="0,0,0,10"
                              HorizontalOptions="Center">
            <Button x:Name="ClearButton"
                    Text="Clear"
                    Clicked="OnClearClicked"
                    WidthRequest="120"/>
            <Button x:Name="CopyButton"
                    Text="Copy"
                    Clicked="OnCopyClicked"
                    WidthRequest="120"/>
        </HorizontalStackLayout>

        <!-- Data Display with ScrollView -->
        <Border Grid.Row="1"
                StrokeThickness="1"
                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>

            <ScrollView x:Name="DataScrollView">
                <Label x:Name="DataLabel"
                       Text="{Binding DataText}"
                       FontFamily="Courier New"
                       FontSize="12"
                       Padding="10"
                       VerticalOptions="Start"
                       LineBreakMode="NoWrap"/>
            </ScrollView>
        </Border>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2" 
              x:Name="LoadingOverlay"
              IsVisible="{Binding IsConnecting}"
              BackgroundColor="#80000000">
            <VerticalStackLayout HorizontalOptions="Center"
                                VerticalOptions="Center"
                                Spacing="10">
                <ActivityIndicator IsRunning="{Binding IsConnecting}"
                                  Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                  WidthRequest="50"
                                  HeightRequest="50"/>
                <Label Text="Connecting to ergometer..."
                       FontSize="18"
                       TextColor="White"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>